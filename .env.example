# SkillMate Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/skillmate

# Authentication (Local)
SESSION_SECRET=your-super-secret-session-key-here-make-it-long-and-random

# AI Integration (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LinkedIn Integration (Optional - for LinkedIn features)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
APP_URL=https://your-app-domain.com

# Environment
NODE_ENV=development

# PostgreSQL Database Details (Auto-generated when using Neon/Replit DB)
PGHOST=your-postgres-host
PGPORT=5432
PGUSER=your-postgres-user
PGPASSWORD=your-postgres-password
PGDATABASE=your-postgres-database